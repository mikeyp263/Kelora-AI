<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Kelora AI — Turn Old Leads Into New Jobs</title>
  <meta name="description" content="Kelora AI calls the leads sitting in your CRM and books new appointments for contractors and home service businesses." />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:title" content="Kelora AI — Turn Old Leads Into New Jobs" />
  <meta property="og:description" content="Kelora AI calls the leads sitting in your CRM and books new appointments for contractors." />
  <meta property="og:type" content="website" />

  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="nav">
    <div class="container nav-inner">
      <div class="brand">
        <div class="logo">K</div>
        <div class="brand-text">
          <div class="brand-name">Kelora AI</div>
          <div class="brand-tag">AI Lead Reactivation for Contractors</div>
        </div>
      </div>

      <div class="nav-actions">
        <a class="btn btn-ghost" href="#how">How it works</a>
        <a class="btn btn-primary" href="https://calendly.com/keloraai/demo" target="_blank" rel="noopener">Book a demo</a>
      </div>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <div class="pill">Built for roofing, HVAC, solar, plumbing, and home services</div>
          <h1>Turn your old leads into new jobs with AI calling.</h1>
          <p class="subhead">
            Kelora AI calls the leads sitting in your CRM and books new appointments automatically.
            Recovering just 1–2 jobs a month can pay for the service.
          </p>

          <div class="cta-row">
            <a class="btn btn-primary btn-lg" href="https://calendly.com/keloraai/demo" target="_blank" rel="noopener">Book a demo</a>
            <a class="btn btn-ghost btn-lg" href="#roi">See the ROI math</a>
          </div>

          <div class="trust">
            <div class="trust-item">
              <div class="dot"></div>
              <span>No new ads required</span>
            </div>
            <div class="trust-item">
              <div class="dot"></div>
              <span>Uses your existing lead list</span>
            </div>
            <div class="trust-item">
              <div class="dot"></div>
              <span>Focused on booked appointments</span>
            </div>
          </div>
        </div>

        <div class="hero-card">
          <div class="card-header">
            <div class="card-title">Example ROI</div>
            <div class="card-sub">Contractor math that makes sense</div>
          </div>
          <div class="roi-grid">
            <div class="roi-box">
              <div class="roi-label">Average job</div>
              <div class="roi-value">$9,000</div>
            </div>
            <div class="roi-box">
              <div class="roi-label">Extra jobs / month</div>
              <div class="roi-value">2</div>
            </div>
            <div class="roi-box roi-highlight">
              <div class="roi-label">Recovered revenue</div>
              <div class="roi-value">$18,000</div>
            </div>
          </div>

          <div class="callout">
            <div class="callout-title">What Kelora AI does</div>
            <ul class="list">
              <li>Calls old leads (and missed opportunities)</li>
              <li>Filters out “not interested”</li>
              <li>Books appointments for your team</li>
              <li>Logs outcomes + transcripts</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how" class="section">
      <div class="container">
        <h2>How it works</h2>
        <p class="section-sub">Simple workflow. Clear results.</p>

        <div class="cards">
          <div class="card">
            <div class="step">1</div>
            <div class="card-h">Upload your old leads</div>
            <div class="card-p">Export a CSV from your CRM (or lead list). We can start with what you already have.</div>
          </div>
          <div class="card">
            <div class="step">2</div>
            <div class="card-h">AI calls automatically</div>
            <div class="card-p">Kelora AI works through your list and has natural conversations to qualify interest.</div>
          </div>
          <div class="card">
            <div class="step">3</div>
            <div class="card-h">Appointments get booked</div>
            <div class="card-p">Interested leads get scheduled. Your team takes it from there and closes the job.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="section alt">
      <div class="container">
        <h2>Why contractors use Kelora AI</h2>
        <p class="section-sub">Because the money is already in your database.</p>

        <div class="cards four">
          <div class="card">
            <div class="card-h">Recover leads you already paid for</div>
            <div class="card-p">Stop letting old leads sit untouched. Reactivation is the lowest-cost revenue.</div>
          </div>
          <div class="card">
            <div class="card-h">AI can work 24/7</div>
            <div class="card-p">Consistent follow-up without burning out your team or adding headcount.</div>
          </div>
          <div class="card">
            <div class="card-h">No new ad spend needed</div>
            <div class="card-p">This is not “more leads.” It’s better conversion from what you already have.</div>
          </div>
          <div class="card">
            <div class="card-h">1–2 extra jobs pays for it</div>
            <div class="card-p">High-ticket services make ROI straightforward and easy to measure.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ROI EXAMPLE -->
    <section id="roi" class="section">
      <div class="container">
        <h2>Real ROI example</h2>
        <p class="section-sub">What a typical campaign can look like.</p>

        <div class="roi-table">
          <div class="roi-row"><span>Old leads in CRM</span><strong>3,000</strong></div>
          <div class="roi-row"><span>AI conversations</span><strong>180</strong></div>
          <div class="roi-row"><span>Appointments booked</span><strong>12</strong></div>
          <div class="roi-row"><span>Jobs closed</span><strong>3</strong></div>
          <div class="roi-row"><span>Average job value</span><strong>$10,000</strong></div>
          <div class="roi-row highlight"><span>Recovered revenue</span><strong>$30,000</strong></div>
        </div>

        <div class="note">
          *Results vary by niche, lead quality, and offer. We track outcomes so you can see ROI clearly.
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section alt">
      <div class="container">
        <h2>FAQ</h2>
        <div class="faq">
          <details>
            <summary>Do you need my CRM?</summary>
            <p>No. Most clients simply export a CSV of leads. Over time, we can automate inputs if you want.</p>
          </details>
          <details>
            <summary>Will the AI sound robotic?</summary>
            <p>No. The system is designed for natural conversations and handles common objections smoothly.</p>
          </details>
          <details>
            <summary>What types of businesses does this work for?</summary>
            <p>Roofing, HVAC, solar, plumbing, and other home service businesses with high-ticket jobs and lead volume.</p>
          </details>
          <details>
            <summary>How quickly can we start?</summary>
            <p>Once we have your lead list and booking details, campaigns can usually launch within a few days.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section cta">
      <div class="container cta-inner">
        <div>
          <h2>Start turning old leads into revenue.</h2>
          <p class="section-sub">Book a short demo and we’ll map out a campaign for your niche.</p>
        </div>
        <a class="btn btn-primary btn-lg" href="https://calendly.com/keloraai/demo" target="_blank" rel="noopener">Book a demo</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div>
        <div class="footer-brand">Kelora AI</div>
        <div class="footer-sub">AI Lead Reactivation for Contractors</div>
      </div>
      <div class="footer-right">
        <a href="mailto:contact@keloraai.com">contact@keloraai.com</a>
      </div>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
